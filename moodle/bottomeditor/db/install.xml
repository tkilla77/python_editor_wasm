<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/bottomeditor/db" VERSION="20260423"
       COMMENT="XMLDB file for mod_bottomeditor">
  <TABLES>
    <TABLE NAME="bottomeditor" COMMENT="Python Exercise activity instances">
      <FIELDS>
        <FIELD NAME="id"           TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="course"       TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="false"/>
        <FIELD NAME="name"         TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="intro"        TYPE="text"              NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="introformat"  TYPE="int"  LENGTH="4"  NOTNULL="true"  SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="prompt"       TYPE="text"              NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="promptformat" TYPE="int"  LENGTH="4"  NOTNULL="true"  SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="startercode"  TYPE="text"              NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="testcode"     TYPE="text"              NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="solutioncode" TYPE="text"              NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="layout"       TYPE="char" LENGTH="20" NOTNULL="true"  SEQUENCE="false" DEFAULT="console"/>
        <FIELD NAME="enablesolution" TYPE="int" LENGTH="1" NOTNULL="true"  SEQUENCE="false" DEFAULT="1"/>
        <FIELD NAME="grade"        TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="false" DEFAULT="100"/>
        <FIELD NAME="timecreated"  TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="false" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="course"  TYPE="foreign" FIELDS="course" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
