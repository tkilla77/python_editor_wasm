# OAuth client IDs — baked into the JS bundle at build time.
# The callback URL is derived automatically from import.meta.url at runtime
# (no env var needed). Register these redirect URIs in both provider consoles:
#   https://bottom.ch/editor/stable/oauth-callback.html
#   https://bottom.ch/editor/latest/oauth-callback.html
#   http://localhost:5173/oauth-callback.html  (dev — can use a separate app)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=
VITE_MICROSOFT_CLIENT_ID=
